APP_NAME=Telugu-First AI Voice Agent
ENVIRONMENT=development
API_V1_PREFIX=/api/v1
DATABASE_URL=sqlite:///./ai_voice.db
DEFAULT_LANGUAGE=te-IN
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:4173,http://localhost:4173
PUBLIC_BASE_URL=
FRONTEND_BASE_URL=

AUTH_ENABLED=true
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
AUTH_SECRET_KEY=dev-insecure-change-me
ACCESS_TOKEN_EXPIRE_MINUTES=720
PRODUCTION_REQUIRE_SECURE_CONFIG=true

META_VERIFY_TOKEN=change-me
META_ACCESS_TOKEN=
META_APP_SECRET=
META_API_VERSION=v23.0
ALLOW_MOCK_META_LEADS=true

AUTO_DISPATCH_CALLS=true
TELEPHONY_PROVIDER=mock

EXOTEL_API_KEY=
EXOTEL_API_TOKEN=
EXOTEL_ACCOUNT_SID=
EXOTEL_CALLER_ID=
EXOTEL_FROM_NUMBER=
EXOTEL_REGION=in
EXOTEL_STATUS_CALLBACK_URL=
# For real phone calls, point this at the public WSS media endpoint with the shared secret:
#   EXOTEL_STREAM_URL=wss://your-public-host/api/v1/telephony/exotel/stream?token=${EXOTEL_STREAM_SECRET}
EXOTEL_STREAM_URL=
EXOTEL_STREAM_SECRET=
EXOTEL_FLOW_URL=

# Phone (Exotel media stream) audio + VAD tuning (defaults suit 8 kHz phone audio).
PHONE_MEDIA_SAMPLE_RATE=8000
PHONE_VAD_SILENCE_MS=700
PHONE_VAD_ENERGY_THRESHOLD=500

SARVAM_API_KEY=
SARVAM_STT_WS_URL=wss://api.sarvam.ai/speech-to-text/ws
SARVAM_STT_URL=https://api.sarvam.ai/speech-to-text
SARVAM_TTS_URL=https://api.sarvam.ai/text-to-speech
SARVAM_STT_MODEL=saaras:v3
SARVAM_TTS_MODEL=bulbul:v3
SARVAM_SPEAKER=anushka

# LLM dialogue manager. For live Telugu replies + qualification, OpenRouter works as an
# OpenAI-compatible endpoint: set LLM_PROVIDER=openai_compatible and point LLM_BASE_URL at it.
#   LLM_PROVIDER=openai_compatible
#   LLM_BASE_URL=https://openrouter.ai/api/v1
#   LLM_API_KEY=sk-or-...
#   LLM_MODEL=mistralai/mistral-small-3.1-24b-instruct
LLM_PROVIDER=mock
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=mock-telugu-qualifier
# Optional OpenRouter attribution headers (ignored by other providers).
LLM_REFERER=
LLM_TITLE=

CRM_PROVIDER=mock
CRM_WEBHOOK_URL=
HANDOFF_CHANNEL=mock
HANDOFF_WEBHOOK_URL=
OPERATOR_DESTINATION=local-operator
MAX_RETRY_ATTEMPTS_PER_LEAD=2
