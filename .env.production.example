APP_NAME=Telugu-First AI Voice Agent
ENVIRONMENT=production
API_V1_PREFIX=/api/v1
DATABASE_URL=postgresql+psycopg://voice:replace-with-strong-password@db:5432/voice
POSTGRES_PASSWORD=replace-with-strong-password
REDIS_URL=redis://redis:6379/0
REDIS_QUEUE_NAME=voice
DEFAULT_LANGUAGE=te-IN
PUBLIC_BASE_URL=https://api.example.com
FRONTEND_BASE_URL=https://app.example.com
CORS_ORIGINS=https://app.example.com

AUTH_ENABLED=true
ADMIN_USERNAME=ops-admin
ADMIN_PASSWORD=replace-with-a-long-random-password
AUTH_SECRET_KEY=replace-with-at-least-32-random-bytes
ACCESS_TOKEN_EXPIRE_MINUTES=720
PRODUCTION_REQUIRE_SECURE_CONFIG=true

META_VERIFY_TOKEN=replace-with-meta-verify-token
META_ACCESS_TOKEN=replace-with-meta-page-access-token
META_APP_SECRET=replace-with-meta-app-secret
META_API_VERSION=v23.0
ALLOW_MOCK_META_LEADS=false

AUTO_DISPATCH_CALLS=true
TELEPHONY_PROVIDER=exotel
EXOTEL_API_KEY=replace-with-exotel-api-key
EXOTEL_API_TOKEN=replace-with-exotel-api-token
EXOTEL_ACCOUNT_SID=replace-with-exotel-account-sid
EXOTEL_CALLER_ID=replace-with-exotel-caller-id
EXOTEL_FROM_NUMBER=replace-with-exotel-from-number
EXOTEL_REGION=in
EXOTEL_STATUS_CALLBACK_URL=https://api.example.com/api/v1/webhooks/exotel/status
# Public WSS media endpoint Exotel streams call audio to; token must equal EXOTEL_STREAM_SECRET.
EXOTEL_STREAM_URL=wss://api.example.com/api/v1/telephony/exotel/stream?token=replace-with-stream-secret
EXOTEL_STREAM_SECRET=replace-with-stream-secret
EXOTEL_FLOW_URL=

PHONE_MEDIA_SAMPLE_RATE=8000
PHONE_VAD_SILENCE_MS=700
PHONE_VAD_ENERGY_THRESHOLD=500

SARVAM_API_KEY=replace-with-sarvam-api-key
SARVAM_STT_WS_URL=wss://api.sarvam.ai/speech-to-text/ws
SARVAM_STT_URL=https://api.sarvam.ai/speech-to-text
SARVAM_TTS_URL=https://api.sarvam.ai/text-to-speech
SARVAM_STT_MODEL=saaras:v3
SARVAM_TTS_MODEL=bulbul:v3
SARVAM_SPEAKER=anushka

LLM_PROVIDER=openai_compatible
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=replace-with-openrouter-api-key
LLM_MODEL=mistralai/mistral-small-3.1-24b-instruct
LLM_REFERER=https://app.example.com
LLM_TITLE=Telugu Voice Agent

CRM_PROVIDER=webhook
CRM_WEBHOOK_URL=https://crm.example.com/voice-leads
HANDOFF_CHANNEL=webhook
HANDOFF_WEBHOOK_URL=https://crm.example.com/operator-handoffs
OPERATOR_DESTINATION=operator-queue
MAX_RETRY_ATTEMPTS_PER_LEAD=2

VITE_API_BASE_URL=https://api.example.com/api/v1
